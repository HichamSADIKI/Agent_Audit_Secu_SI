# ── Build ─────────────────────────────────────────────────────────────────────
FROM node:26-alpine AS builder

WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1

# Les variables NEXT_PUBLIC_* sont inlinées par Next.js AU BUILD (npm run build) —
# une variable d'environnement posée seulement au runtime du conteneur (docker-compose
# `environment:`) n'a AUCUN effet sur le bundle déjà figé. Doit donc transiter en build-arg.
ARG NEXT_PUBLIC_API_URL=
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

COPY package.json package-lock.json ./
RUN npm ci

COPY . .
RUN npm run build

# ── Runtime ───────────────────────────────────────────────────────────────────
FROM node:26-alpine AS runner

WORKDIR /app
ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0

RUN addgroup -S nextjs && adduser -S nextjs -G nextjs

# Sortie "standalone" : serveur Node minimal + assets statiques.
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static

USER nextjs
EXPOSE 3000

CMD ["node", "server.js"]
